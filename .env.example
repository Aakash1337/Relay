# RELAY configuration — copy to .env and adjust. Never commit .env.
# Every variable is read by pydantic-settings (src/relay/config.py) with the
# RELAY_ prefix. No secrets live in code; this file documents shape only.

# ── Database ────────────────────────────────────────────────────────────────
# Admin URL: used for migrations only (owns the schema, can create roles).
RELAY_DATABASE_URL=postgresql+psycopg://relay:relay@localhost:5432/relay
# App URL: what the API/worker use. relay_app is a non-superuser role subject
# to FORCED row-level security — tenant isolation is enforced by Postgres.
RELAY_APP_DATABASE_URL=postgresql+psycopg://relay_app:relay_app@localhost:5432/relay
# Password assigned to the relay_app role at migration time.
RELAY_APP_DB_PASSWORD=relay_app

# ── API ─────────────────────────────────────────────────────────────────────
# Token required by the tenant-bootstrap endpoint. If unset, bootstrap is off.
RELAY_ADMIN_TOKEN=change-me
RELAY_ENV=dev

# ── Send safety ─────────────────────────────────────────────────────────────
# Phase 0: there is no real sender implementation; this flag must stay false.
# Flipping it does NOT enable sending — it is one of several independent
# layers (worker check, DB trigger, absent provider) that all must agree.
RELAY_REAL_SEND_ENABLED=false

# ── Guardrails (dumb limits — the harness, not the planner) ────────────────
RELAY_MAX_ITERATIONS_DEFAULT=100
RELAY_BUDGET_UNITS_DEFAULT=50

# ── Compute routing cost stubs (units per task) ─────────────────────────────
RELAY_COST_LOCAL_UNITS=0.1
RELAY_COST_HOSTED_UNITS=1.0
RELAY_COST_HOSTED_EXTENDED_UNITS=3.0

# ── Compute backends (Phase 1A) ─────────────────────────────────────────────
# Each tier picks a provider and a model, independently. Swapping the
# orchestrator (hosted tier) or the workhorse (local tier) to another
# provider later is a change HERE, never in code. 'offline' is
# deterministic and hermetic (no network) — the default for dev and CI.
# There is no silent fallback: a configured backend that can't start
# fails loudly.
RELAY_COMPUTE_LOCAL_BACKEND=offline    # offline | openai | google | anthropic
RELAY_COMPUTE_HOSTED_BACKEND=offline   # offline | openai | google | anthropic
RELAY_LOCAL_MODEL=                     # e.g. gemma-4-31b-it (google) or qwen2.5 (openai)
RELAY_HOSTED_MODEL=                    # e.g. gemini-3.5-flash (google) or a Claude model

# Provider: any OpenAI-compatible server (default port is Ollama's).
RELAY_OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
RELAY_OPENAI_COMPAT_API_KEY=local-no-auth    # Ollama ignores this

# Provider: Google Gemini API (serves Gemini AND Gemma models).
RELAY_GOOGLE_API_KEY=

# Provider: the Claude API.
RELAY_ANTHROPIC_API_KEY=

RELAY_COMPUTE_TIMEOUT_SECONDS=60
RELAY_COMPUTE_MAX_OUTPUT_TOKENS=1024   # raise (e.g. 4096) for thinking models

# USD per guardrail cost unit for the economics projection. 0 = not
# calibrated; the USD figure is then omitted rather than guessed.
RELAY_COST_UNIT_USD=0

# ── Pipeline thresholds ─────────────────────────────────────────────────────
# Leads scoring below this are scored_rejected. The default (0.3) sits below
# the offline backend's floor so hermetic dev runs qualify by default.
RELAY_FIT_SCORE_THRESHOLD=0.3

# ── CRM sync (one-way mirror, best-effort — never a gate) ───────────────────
RELAY_CRM_BACKEND=none                       # none | memory | espo
RELAY_ESPO_BASE_URL=                         # e.g. https://crm.example.com
RELAY_ESPO_API_KEY=

# ── Tenancy primitives ──────────────────────────────────────────────────────
# Master key for per-tenant key derivation (HKDF). Dev value only; production
# uses a KMS-managed key (Phase 3).
RELAY_MASTER_KEY=dev-master-key-not-for-production

# ── Rate limiting & retries (Phase 2) ───────────────────────────────────────
# Requests/second per external target; 0 disables the bucket. Waits beyond
# max_wait raise Backpressure and the work parks (error_retryable).
RELAY_RATE_LIMIT_LOCAL_RPS=0
RELAY_RATE_LIMIT_HOSTED_RPS=0
RELAY_RATE_LIMIT_CRM_RPS=0
RELAY_RATE_LIMIT_MAX_WAIT_SECONDS=30
# Bounded retry for transient compute failures only.
RELAY_COMPUTE_RETRY_ATTEMPTS=2
RELAY_COMPUTE_RETRY_BASE_SECONDS=0.5

# ── Crash recovery (Phase 2) ────────────────────────────────────────────────
RELAY_RECOVERY_STALE_AFTER_SECONDS=300

# ── Alerting (Phase 2) ──────────────────────────────────────────────────────
RELAY_ALERT_SPEND_UNITS_PER_HOUR=100
RELAY_ALERT_FAILURE_STREAK=3
RELAY_ALERT_QUEUE_STALE_SECONDS=600
RELAY_ALERT_WEBHOOK_URL=                     # Slack/n8n hook; empty = log only

# ── Real sender: Phase 1C pilot (§6 — docs/decisions/sending-provider.md) ───
# 'none' keeps real sending structurally absent. 'ses' = SES SANDBOX,
# self-to-self only. All attests below are recorded human claims.
RELAY_SENDER_PROVIDER=none                   # none | ses

# AWS credentials & region — STANDARD AWS SDK names so boto3 auto-loads them.
# The worker/poller entrypoints load .env into the environment for boto3.
# RELAY never reads or stores the secret; region is also read for the gate.
AWS_ACCESS_KEY_ID=                           # from IAM user relay-ses-pilot
AWS_SECRET_ACCESS_KEY=                       # paste your secret; never committed
AWS_REGION=                                  # us-east-2

RELAY_SES_FROM=                              # pilot@testings.work
RELAY_SES_CONFIGURATION_SET=                 # optional
# Pilot recipient allowlist: comma-separated verified sandbox inboxes. A
# real send may target ONLY these addresses (fail-closed: empty = no send).
RELAY_PILOT_RECIPIENTS=                      # you@gmail.com[,other@…]
RELAY_UNSUBSCRIBE_MAILTO=                    # List-Unsubscribe mailto (required)
RELAY_UNSUBSCRIBE_URL=                       # public /unsubscribe URL -> one-click (RFC 8058)
RELAY_SENDER_IDENTITY_APPROVED=false         # attest: SES identity Verified
RELAY_SENDER_DOMAIN_AUTHENTICATED=false      # attest: SPF/DKIM/DMARC live
RELAY_PROVIDER_TERMS_RECORD=                 # docs/decisions/sending-provider.md
RELAY_REAL_SEND_DAILY_CAP=5
# Deliverability pacing (Phase 3) - all optional, 0 = off. Pacing DEFERS a
# queued job to a later worker tick; it never blocks a lead terminally.
RELAY_REAL_SEND_HOURLY_CAP=0                 # rolling-hour cap per mailbox
RELAY_REAL_SEND_MIN_SPACING_SECONDS=0        # min gap between two sends
RELAY_WARMUP_DAILY_START=0                   # day-0 daily cap (0 = no ramp)
RELAY_WARMUP_DAILY_INCREMENT=0               # daily cap growth per day
RELAY_BOUNCE_COMPLAINT_WINDOW_DAYS=7
RELAY_MAX_BOUNCES_COMPLAINTS_IN_WINDOW=2
# SES event ingestion: webhook token (SNS HTTPS) and/or SQS queue (polling).
# The relay-ses-events queue is Part 2 — leave empty until it exists.
RELAY_SES_WEBHOOK_TOKEN=
RELAY_SQS_QUEUE_URL=
