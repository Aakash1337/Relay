# RELAY configuration — copy to .env and adjust. Never commit .env.
# Every variable is read by pydantic-settings (src/relay/config.py) with the
# RELAY_ prefix. No secrets live in code; this file documents shape only.

# ── Database ────────────────────────────────────────────────────────────────
# Admin URL: used for migrations only (owns the schema, can create roles).
RELAY_DATABASE_URL=postgresql+psycopg://relay:relay@localhost:5432/relay
# App URL: what the API/worker use. relay_app is a non-superuser role subject
# to FORCED row-level security — tenant isolation is enforced by Postgres.
RELAY_APP_DATABASE_URL=postgresql+psycopg://relay_app:relay_app@localhost:5432/relay
# Password assigned to the relay_app role at migration time.
RELAY_APP_DB_PASSWORD=relay_app

# ── API ─────────────────────────────────────────────────────────────────────
# Token required by the tenant-bootstrap endpoint. If unset, bootstrap is off.
RELAY_ADMIN_TOKEN=change-me
RELAY_ENV=dev

# ── Send safety ─────────────────────────────────────────────────────────────
# Phase 0: there is no real sender implementation; this flag must stay false.
# Flipping it does NOT enable sending — it is one of several independent
# layers (worker check, DB trigger, absent provider) that all must agree.
RELAY_REAL_SEND_ENABLED=false

# ── Guardrails (dumb limits — the harness, not the planner) ────────────────
RELAY_MAX_ITERATIONS_DEFAULT=100
RELAY_BUDGET_UNITS_DEFAULT=50

# ── Compute routing cost stubs (units per task) ─────────────────────────────
RELAY_COST_LOCAL_UNITS=0.1
RELAY_COST_HOSTED_UNITS=1.0
RELAY_COST_HOSTED_EXTENDED_UNITS=3.0

# ── Tenancy primitives ──────────────────────────────────────────────────────
# Master key for per-tenant key derivation (HKDF). Dev value only; production
# uses a KMS-managed key (Phase 3).
RELAY_MASTER_KEY=dev-master-key-not-for-production
