# The runtime environment contract for deploy/docker-compose.prod.yml.
# This file documents SHAPE ONLY — never commit a filled-in copy.
#
# In a real deployment this file is assembled at boot from a secret store
# (GCP Secret Manager in deploy/gcp/, AWS Secrets Manager, Vault, …) into a
# tmpfs path such as /run/relay/relay.env, mode 600, and passed to compose
# via --env-file. Nothing sensitive lands on persistent disk or in the image.

# ── Image ───────────────────────────────────────────────────────────────────
RELAY_IMAGE=                       # e.g. europe-west1-docker.pkg.dev/PROJECT/relay/relay:latest

# ── Database (external managed Postgres 16) ────────────────────────────────
# Admin DSN (migrations; needs CREATEROLE) and runtime DSN (relay_app, RLS).
# Keep sslmode=require for managed databases.
RELAY_DATABASE_URL=                # postgresql+psycopg://relay:PW@HOST:5432/relay?sslmode=require
RELAY_APP_DATABASE_URL=            # postgresql+psycopg://relay_app:PW@HOST:5432/relay?sslmode=require
RELAY_APP_DB_PASSWORD=             # password migrate assigns to relay_app

# ── Core secrets ────────────────────────────────────────────────────────────
RELAY_ADMIN_TOKEN=                 # long + random; guards ticks, onboarding, /admin
RELAY_MASTER_KEY=                  # long + random; per-tenant key derivation
RELAY_EMAIL_HASH_PEPPER=           # long + random; do NOT rotate casually

# ── Compute tiers ───────────────────────────────────────────────────────────
RELAY_COMPUTE_LOCAL_BACKEND=offline
RELAY_COMPUTE_HOSTED_BACKEND=offline
RELAY_LOCAL_MODEL=
RELAY_HOSTED_MODEL=
RELAY_GOOGLE_API_KEY=

# ── AWS (SES/SQS — cross-cloud by design; outbound only) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
RELAY_SES_FROM=
RELAY_PILOT_RECIPIENTS=
RELAY_SQS_QUEUE_URL=
RELAY_UNSUBSCRIBE_MAILTO=
RELAY_UNSUBSCRIBE_URL=
RELAY_SENDER_PROVIDER=none
RELAY_REAL_SEND_ENABLED=false
RELAY_SENDER_IDENTITY_APPROVED=false
RELAY_SENDER_DOMAIN_AUTHENTICATED=false

# ── Ingress + spine ─────────────────────────────────────────────────────────
TUNNEL_TOKEN=                      # Cloudflare Tunnel token (tunnel profile)
N8N_ENCRYPTION_KEY=                # keep stable once set; n8n credentials depend on it
COMPOSE_PROFILES=                  # "tunnel" to enable cloudflared
